# ==========================================
# Debian XFCE VNC Python 项目配置
# ==========================================

# 1. 项目与容器名称
PROJECT_NAME=vnc-python-dev

# 2. 端口配置
# 主机访问 noVNC (Web 模式) 的端口
HOST_PORT_NOVNC=9601
# 主机访问 VNC (直接桌面连接) 的端口
HOST_PORT_VNC=5901

# 3. 桌面环境配置
# VNC 进入桌面的密码
VNC_PASSWORD=1234
# 时区
TIMEZONE=Asia/Shanghai
# 分辨率
RESOLUTION=1280x720